# API
PORT=4000
NODE_ENV=development
DATABASE_URL=./dev.sqlite
JWT_SECRET=change-me-in-env-before-production-unsafe-key
ACCESS_TOKEN_TTL=15m
FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
LIBREOFFICE_PREVIEW_ENABLED=true
LIBREOFFICE_DOCKER_BIN=docker
LIBREOFFICE_CONTAINER_NAME=oto-libreoffice
LIBREOFFICE_HOST_STORAGE_PATH=./apps/api/storage
LIBREOFFICE_CONTAINER_STORAGE_ROOT=/workspace/storage
LIBREOFFICE_CONVERT_TIMEOUT_MS=120000

# External LLM (OpenRouter)
LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# ElevenLabs Voice
VOICE_PROVIDER=elevenlabs
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_WEBHOOK_SECRET=

# Web
VITE_API_URL=http://localhost:4000
